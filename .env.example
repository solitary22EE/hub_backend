# ──────────────────────────────────────────
# Application
# ──────────────────────────────────────────
DEBUG=false

# ──────────────────────────────────────────
# Database (PostgreSQL)
# ──────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://

# ──────────────────────────────────────────
# Redis
# ──────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ──────────────────────────────────────────
# JWT Authentication
# Generate with: openssl rand -hex 32
# ──────────────────────────────────────────
SECRET_KEY=replace-with-openssl-rand-hex-32-output
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ──────────────────────────────────────────
# Ollama (LLM — used by AI service directly)
# ──────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ──────────────────────────────────────────
# AI Service (LLM + RAG + document extraction)
# Run: cd hub-AI && uvicorn app.main:app --port 8003
# ──────────────────────────────────────────
AI_SERVICE_URL=http://localhost:8003

# ──────────────────────────────────────────
# ChromaDB (Vector store for RAG)
# ──────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8002

# ──────────────────────────────────────────
# RabbitMQ (Message queue)
# ──────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# ──────────────────────────────────────────
# AWS / S3 (File storage)
# Credentials will be shared by instructor
# ──────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
S3_BUCKET_NAME=hub-files-dev

# ──────────────────────────────────────────
# Google OAuth (optional)
# ──────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
